<view class="container">
  <view class="tab-bar">
    <view
      class="tab-item {{tab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="onSwitchTab"
      data-tab="{{item.key}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-view">
    <block wx:if="{{tab === 'post'}}">
      <view class="list-item" wx:for="{{list}}" wx:key="id" bindtap="onItemTap" data-type="post" data-id="{{item.id}}">
        <view class="list-item-main">
          <view class="list-item-title">{{item.title}}</view>
          <view class="list-item-content">{{item.content}}</view>
          <view class="list-item-meta">{{item.author}} · {{item.time}}</view>
          <view class="list-item-meta" wx:if="{{item.activityTitle}}">关联赛事：{{item.activityTitle}}</view>
          <button class="mini-btn danger" size="mini" catchtap="onDeleteTap" data-type="post" data-id="{{item.id}}">删除</button>
        </view>
        <view class="list-item-status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="empty-tip" wx:if="{{list.length === 0}}">{{emptyText.post}}</view>
    </block>

    <block wx:if="{{tab === 'comment'}}">
      <view class="list-item" wx:for="{{list}}" wx:key="id" bindtap="onItemTap" data-type="comment" data-id="{{item.id}}">
        <view class="list-item-main">
          <view class="list-item-content">{{item.content}}</view>
          <view class="list-item-meta">{{item.author}} · 评论于《{{item.postTitle}}》 · {{item.time}}</view>
          <view class="list-item-meta" wx:if="{{item.postAuthor}}">主题帖作者：{{item.postAuthor}}</view>
          <button class="mini-btn danger" size="mini" catchtap="onDeleteTap" data-type="comment" data-id="{{item.id}}">删除</button>
        </view>
        <view class="list-item-status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="empty-tip" wx:if="{{list.length === 0}}">{{emptyText.comment}}</view>
    </block>

    <block wx:if="{{tab === 'activity'}}">
      <view class="list-item" wx:for="{{list}}" wx:key="id" bindtap="onItemTap" data-type="activity" data-id="{{item.id}}">
        <view class="list-item-main">
          <view class="list-item-title">{{item.name}}</view>
          <view class="list-item-content">{{item.intro}}</view>
          <view class="list-item-meta">{{item.typeText}} · {{item.activityStateText}} · {{item.date}}</view>
          <view class="list-item-meta">{{item.city}} · {{item.address}} · 提交者 {{item.submitter}}</view>
          <button class="mini-btn danger" size="mini" catchtap="onDeleteTap" data-type="activity" data-id="{{item.id}}">删除</button>
        </view>
        <view class="list-item-status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="empty-tip" wx:if="{{list.length === 0}}">{{emptyText.activity}}</view>
    </block>

    <block wx:if="{{tab === 'user'}}">
      <view class="list-item" wx:for="{{list}}" wx:key="id">
        <view class="list-item-main">
          <view class="user-item-header">
            <view class="user-avatar-sm">{{item.avatar}}</view>
            <view class="user-name-area">
              <view class="list-item-title">用户ID：{{item.userID || item.id}}</view>
              <view class="list-item-meta">用户类型：{{item.userType}}</view>
            </view>
          </view>
          <view class="list-item-meta">密码：{{item.userPassword || '-'}}</view>
          <view class="list-item-meta">资料：{{item.name || item.username || '-'}} · {{item.phone || '-'}} · {{item.email || '-'}}</view>
          <view class="user-actions">
            <button
              class="mini-btn"
              size="mini"
              bindtap="onUserStatusTap"
              data-id="{{item.id}}"
              data-type="{{item.userType}}"
            >
              {{item.userType === 'disabled' ? '启用' : '禁用'}}
            </button>
            <button
              class="mini-btn danger"
              size="mini"
              catchtap="onDeleteTap"
              data-id="{{item.id}}"
              data-type="user"
            >
              删除
            </button>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{list.length === 0}}">{{emptyText.user}}</view>
    </block>
  </scroll-view>
  <admin-tabbar current="audit" />
</view>
