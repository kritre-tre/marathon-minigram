/* pages/admin-audit/admin-audit.wxss */
.container {
  min-height: 100vh;
  background-color: var(--background);
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background-color: var(--background-white);
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 2rpx solid var(--divider);
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--primary);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background-color: var(--primary);
  border-radius: 4rpx;
}

.scroll-view {
  height: calc(100vh - 88rpx);
  padding-bottom: 160rpx;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: flex-start;
  background-color: var(--background-white);
  margin: 16rpx 30rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.list-item-main {
  flex: 1;
  min-width: 0;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-item-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 8rpx;
}

.list-item-meta {
  font-size: 22rpx;
  color: var(--text-hint);
}

.list-item-status {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.status-pending {
  background-color: #FFF3E0;
  color: #F57C00;
}

.status-approved {
  background-color: #E8F5E9;
  color: #388E3C;
}

.status-rejected {
  background-color: #FFEBEE;
  color: #D32F2F;
}

/* 用户管理特定样式 */
.user-item-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-avatar-sm {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.user-name-area {
  flex: 1;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 30rpx;
  font-size: 28rpx;
  color: var(--text-hint);
}
