/* pages/edit-profile/edit-profile.wxss */
.container {
  min-height: 100vh;
  background-color: var(--background);
}

.scroll-view {
  height: 100vh;
  padding-bottom: 40rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background-color: var(--background-white);
}

.avatar-lg {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: var(--primary);
  margin-bottom: 20rpx;
}

.change-avatar {
  font-size: 28rpx;
  color: var(--primary);
}

/* 表单卡片 */
.form-card {
  margin: 20rpx;
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: var(--background);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
  color: var(--text-primary);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background-color: var(--primary);
  color: var(--text-white);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 40rpx;
}
