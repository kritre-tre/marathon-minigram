/* pages/register/register.wxss */
.container {
  min-height: 100vh;
  background-color: var(--background);
}

.scroll-view {
  height: 100vh;
}

.register-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.logo {
  font-size: 100rpx;
  margin-top: 40rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-dark);
  margin-top: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
  margin-bottom: 40rpx;
}

.form-group {
  width: 100%;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background-color: var(--background-white);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.code-input-wrapper {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
  margin-right: 16rpx;
}

.send-code-btn {
  width: 200rpx;
  height: 88rpx;
  background-color: var(--primary-light);
  color: var(--primary-dark);
  border-radius: 16rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.agreement {
  width: 100%;
  display: flex;
  align-items: center;
  margin: 24rpx 0 40rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-white);
}

.checkbox.checked {
  background-color: var(--primary);
  border-color: var(--primary);
}

.agreement text:last-child {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background-color: var(--primary);
  color: var(--text-white);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.login-hint {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}

.login-hint text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.login-link {
  color: var(--primary) !important;
  font-weight: bold;
  margin-left: 12rpx;
}
