<!--pages/index/index.wxml-->
<view class="container">
  <scroll-view scroll-y class="scroll-view">
    <!-- 轮播图区域 -->
    <swiper class="banner-swiper" 
            indicator-dots="{{true}}" 
            autoplay="{{true}}" 
            circular="{{true}}"
            indicator-color="rgba(255,255,255,0.5)"
            indicator-active-color="#FFFFFF">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item" style="background: {{item.gradient}};">
          <view class="banner-content">
            <view class="banner-title">{{item.title}}</view>
            <view class="banner-subtitle">{{item.subtitle}}</view>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <!-- 热门赛事标题 -->
    <view class="section-title">热门赛事</view>

    <!-- 活动网格 -->
    <view class="activity-grid">
      <view class="activity-card" 
            wx:for="{{activities}}" 
            wx:key="id"
            bindtap="onActivityTap"
            data-id="{{item.id}}">
        <view class="activity-cover" style="background: {{item.gradient}};">
          <view class="cover-title">{{item.name}}</view>
        </view>
        <view class="activity-info">
          <view class="activity-name">{{item.name}}</view>
          <view class="activity-city">📍 {{item.city}}</view>
          <view class="activity-date">📅 {{item.date}}</view>
          <view class="badge {{item.status === '招募中' ? 'badge-recruiting' : 'badge-ended'}}">
            {{item.status}}
          </view>
        </view>
      </view>
    </view>

    <!-- 查看更多按钮 -->
    <view class="view-more-wrapper">
      <button class="btn-secondary view-more-btn" bindtap="onViewMore">查看更多</button>
    </view>
  </scroll-view>
</view>
