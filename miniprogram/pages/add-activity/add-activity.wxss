/* pages/add-activity/add-activity.wxss */
.container {
  min-height: 100vh;
  background-color: var(--background);
}

.scroll-view {
  height: 100vh;
  padding-bottom: 40rpx;
}

/* 表单卡片 */
.form-card {
  margin: 20rpx;
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-group.half {
  flex: 1;
}

.form-group.half:first-child {
  margin-right: 20rpx;
}

.form-row {
  display: flex;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: var(--background);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background-color: var(--background);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.form-textarea.large {
  height: 300rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background-color: var(--primary);
  color: var(--text-white);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 40rpx;
}
