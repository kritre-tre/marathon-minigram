.container {
  min-height: 100vh;
  background: #fff5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.activity-name {
  margin-top: 8rpx;
  color: #666;
  font-size: 26rpx;
}

.form-item {
  margin-top: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 84rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.btn {
  margin-top: 30rpx;
  background: #e8a5a5;
  color: #fff;
  border: none;
}
