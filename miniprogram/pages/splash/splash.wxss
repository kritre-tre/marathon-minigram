/* pages/splash/splash.wxss */
.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--background);
}

.splash-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  font-size: 200rpx;
  margin-bottom: 40rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-dark);
  margin-bottom: 60rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
