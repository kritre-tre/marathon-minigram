.container { min-height: 100vh; background: #fff5f5; padding: 20rpx; }
.item { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; }
.meta { color: #666; font-size: 24rpx; margin-bottom: 8rpx; }
.content { color: #333; font-size: 28rpx; line-height: 1.5; }
.actions { margin-top: 12rpx; display: flex; gap: 10rpx; }
.danger { background: #f44336; color: #fff; border: none; }
.empty { text-align: center; color: #999; margin-top: 60rpx; }
