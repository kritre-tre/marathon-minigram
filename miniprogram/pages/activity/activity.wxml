<view class="container">
  <view class="page-title">赛事活动</view>

  <view class="card search-card">
    <view class="search-wrapper">
      <input
        class="search-input"
        placeholder="搜索赛事名称、城市..."
        value="{{searchText}}"
        bindinput="onSearchInput"
      />
      <view class="search-btn" bindtap="onSearch">
        <text>搜</text>
      </view>
    </view>

    <view class="filter-wrapper">
      <picker class="filter-picker" mode="selector" range="{{typeOptions}}" bindchange="onTypeChange">
        <view class="picker-content">{{typeOptions[typeIndex]}}<text class="arrow">▼</text></view>
      </picker>

      <picker class="filter-picker" mode="selector" range="{{statusOptions}}" bindchange="onStatusChange">
        <view class="picker-content">{{statusOptions[statusIndex]}}<text class="arrow">▼</text></view>
      </picker>

      <picker class="filter-picker" mode="selector" range="{{cityOptions}}" bindchange="onCityChange">
        <view class="picker-content">{{cityOptions[cityIndex]}}<text class="arrow">▼</text></view>
      </picker>
    </view>
  </view>

  <scroll-view scroll-y class="activity-list">
    <view
      class="activity-card"
      wx:for="{{filteredActivities}}"
      wx:key="id"
      bindtap="onActivityTap"
      data-id="{{item.id}}"
    >
      <image wx:if="{{item.hasCover}}" class="activity-cover-img" src="{{item.coverSrc}}" mode="aspectFill" />
      <view wx:else class="activity-cover" style="background: {{item.gradient}};">
        <view class="cover-title">{{item.name}}</view>
      </view>
      <view class="activity-info">
        <view class="activity-name">{{item.name}}</view>
        <view class="activity-city">📍 {{item.city}}</view>
        <view class="activity-date">📅 {{item.date}}</view>
        <view class="activity-type">类型：{{item.typeText}}</view>
        <view class="badge {{item.statusClass}}">{{item.status}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="fab" bindtap="onAddActivity">
    <text>+</text>
  </view>
</view>
