<view class="container">
  <view class="card">
    <input class="input" password placeholder="旧密码" data-field="oldPassword" bindinput="onInput" />
    <input class="input" password placeholder="新密码" data-field="newPassword" bindinput="onInput" />
    <input class="input" password placeholder="确认新密码" data-field="confirmPassword" bindinput="onInput" />
    <button class="btn" bindtap="onSubmit">提交</button>
  </view>
</view>
